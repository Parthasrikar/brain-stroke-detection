# Environment variables for Docker deployment
# Copy this file to .env and fill in your values

# MongoDB Configuration
MONGO_URL=mongodb://root:password123@mongodb:27017
DB_NAME=brain_stroke_db

# Google Gemini API Key (for rehabilitation advice)
GEMINI_API_KEY=AIzaSyBF86V4v4TJmsivW7SiWq0civkMfD7z9Kc

# JWT Secret Key (CHANGE IN PRODUCTION!)
JWT_SECRET=your_jwt_secret_key_here_change_in_production

# CORS Origins (for cross-origin requests)
CORS_ORIGINS=http://localhost:80,http://localhost:8000,http://localhost

# Optional: API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true

# Optional: Environment
ENVIRONMENT=development
